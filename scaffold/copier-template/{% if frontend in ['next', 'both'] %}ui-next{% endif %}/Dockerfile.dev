FROM node:20-alpine
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@latest --activate

COPY package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile || pnpm install

COPY . .
# Bind to 0.0.0.0 for containerized dev
EXPOSE 3000
CMD ["sh", "-lc", "pnpm install --frozen-lockfile || pnpm install && pnpm exec next dev --turbopack --hostname 0.0.0.0 --port 3000"]
