FROM node:25-alpine
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@latest --activate

COPY package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile || pnpm install

COPY . .
# Bind to 0.0.0.0 for containerized dev
EXPOSE 3000
CMD ["sh", "-lc", "CI=true pnpm install --no-frozen-lockfile --force --prod=false && pnpm exec next dev --webpack --hostname 0.0.0.0 --port 3000"]
