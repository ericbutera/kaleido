FROM node:20-alpine
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@latest --activate

COPY package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile || pnpm install

COPY . .
# Bind to 0.0.0.0 for containerized dev
EXPOSE 5173
CMD ["sh", "-lc", "pnpm install --frozen-lockfile || pnpm install && pnpm run dev -- --host 0.0.0.0 --port 5173"]
